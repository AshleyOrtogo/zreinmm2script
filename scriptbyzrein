function SpawnFakeItem(dbKey, quantity)
    -- Look up in DB
    local entry = ITEM_DB[dbKey]
    if not entry then
        local q = tostring(dbKey):lower()
        for k, v in pairs(ITEM_DB) do
            if v.Name:lower() == q then entry = v dbKey = k break end
        end
    end
    if not entry then warn('[KnifeSpawner] Unknown knife: '..tostring(dbKey)) return nil end

    quantity = math.clamp(math.floor(tonumber(quantity) or 1), 1, 99)

    -- Use unique key based on dbKey so it doesn't collide with real items
    local uid = 'FAKE_' .. dbKey .. '_' .. HttpService:GenerateGUID(false):sub(1,8)

    local item = {
        name     = entry.Name,
        rarity   = entry.Rarity,
        image    = entry.Image,
        chroma   = entry.Chroma or false,
        quantity = quantity,
        dbKey    = dbKey,
        uid      = uid,
        isFake   = true,
    }
    fakeItems[uid] = item
    _G.MM2FakeItems = fakeItems

    local ok = injectIntoGame(uid, item)
    if ok then
        print(string.format('[KnifeSpawner] [OK] "%s" (%s) x%d -> uid: %s', item.name, item.rarity, quantity, uid))
    else
        fakeItems[uid] = nil
        _G.MM2FakeItems = fakeItems
        warn('[KnifeSpawner] [ERR] Hook failed for: '..item.name)
    end
    return uid
end

function RemoveFakeKnife(uid)
    if not fakeItems[uid] then return end
    removeFromGame(uid)
    fakeItems[uid] = nil
    _G.MM2FakeItems = fakeItems
    print('[KnifeSpawner] [DEL] Removed: '..uid)
end

function ClearAllFakeKnives()
    for uid in pairs(fakeItems) do
        removeFromGame(uid)
    end
    table.clear(fakeItems)
    _G.MM2FakeItems = fakeItems
    print('[KnifeSpawner] [DEL] Cleared all fake knives')
end

-- -- Rarity sort order ---------------------------------------------
local RARITY_ORDER = {
    Unique=100, Victim=100, Ancient=90,
    Godly=80,   Clown=80,  Legendary=70,
    Halloween=75, Christmas=75, Easter=70,
    Rare=60, Uncommon=50, Common=40,
}
local function rarityOrder(k)
    local d = SyncDB.Weapons and SyncDB.Weapons[k]
    return (d and RARITY_ORDER[d.Rarity]) or 0
end

-- -- Helper -------------------------------------------------------
local function find(root, ...)
    local cur = root
    for _, n in ipairs({...}) do
        if not cur then return nil end
        cur = cur:FindFirstChild(n)
    end
    return cur
end

-- -- GUI state (persists across opens) ----------------------------
local mockGui   = nil
local C         = nil
local yourSlots = {}

-- -- Per-trade state (reset every open) ---------------------------
local tradeOpen = false
local yourOffer = {}
local offerQty  = {}
local slotOf    = {}
local invQty    = {}
local invCells  = {}

-- -- Persistent fake item qty (survives across mock trades) -------
-- Only tracks visual/fake items (_G.MM2FakeItems). Never resets.
-- Decrements on accept, restores on slot-remove (item returned).
-- Real items are never tracked here -- always read fresh from PD.
local mockInvQty = {}  -- [displayName] = remaining qty (stable across opens)

local function isFake(key)
    return _G.MM2FakeItems and _G.MM2FakeItems[key] ~= nil
end

-- Returns the display name for a fake item key (stable mockInvQty index)
local function fakeDisplayName(key)
    local data = SyncDB and SyncDB.Weapons and SyncDB.Weapons[key]
    return data and data.ItemName or key
end

-- -- Cooldown callbacks (fresh every open) ------------------------
local doRestartCooldown = nil
local doGrayOut         = nil

-- -- Offer slot qty label -----------------------------------------
local function updateSlotQty(slotIdx)
    local slot = yourSlots[slotIdx]
    if not slot then return end
    local qty = offerQty[slotIdx] or 0
    local am  = find(slot, "Container", "Amount")
    if am then
        am.Text    = qty > 1 and ("x"..qty) or ""
        am.Visible = qty > 1
    end
end

-- -- Inventory cell visibility -------------------------------------
local function updateCellVis(itemKey)
    local cell = invCells[itemKey]
    if not cell then return end
    local qty = invQty[itemKey] or 0
    cell.Visible = qty > 0
    if qty > 0 then
        local am = find(cell, "Container", "Amount")
        if am then
            am.Text    = qty > 1 and ("x"..qty) or ""
            am.Visible = qty > 1
        end
    end
end

-- -- Offer empty check ---------------------------------------------
local function offerIsEmpty()
    for i = 1, 4 do if yourOffer[i] then return false end end
    return true
end

-- -- Remove ONE from offer slot ------------------------------------
local function clearSlot(slotIdx)
    local slot = yourSlots[slotIdx]
    local key  = yourOffer[slotIdx]
    if not slot or not key then return end

    local newQty = (offerQty[slotIdx] or 1) - 1
    offerQty[slotIdx] = newQty

    invQty[key] = (invQty[key] or 0) + 1
    -- Fake item: restore persistent qty using display name as stable key
    if isFake(key) then
        local dname = fakeDisplayName(key)
        mockInvQty[dname] = (mockInvQty[dname] or 0) + 1
    end
    updateCellVis(key)

    if newQty <= 0 then
        local ic = find(slot, "Container", "Icon")
        local lb = find(slot, "ItemName", "Label") or find(slot, "ItemName", "ColoredName")
        local am = find(slot, "Container", "Amount")
        if ic then ic.Image = "" end
        if lb then lb.Text  = "" end
        if am then am.Text  = ""; am.Visible = false end
        slot.Visible       = false
        yourOffer[slotIdx] = nil
        offerQty[slotIdx]  = nil
        slotOf[key]        = nil
    else
        updateSlotQty(slotIdx)
    end

    if offerIsEmpty() then
        if doGrayOut then doGrayOut() end
    else
        if doRestartCooldown then doRestartCooldown() end
    end
end

-- -- Add one item to offer -----------------------------------------
local function addToOffer(itemKey)
    local rem = invQty[itemKey] or 0
    if rem <= 0 then return end

    local existing = slotOf[itemKey]
    if existing then
        invQty[itemKey]    = rem - 1
        if isFake(itemKey) then
            local dname = fakeDisplayName(itemKey)
            mockInvQty[dname] = (mockInvQty[dname] or rem) - 1
        end
        offerQty[existing] = (offerQty[existing] or 0) + 1
        updateCellVis(itemKey)
        updateSlotQty(existing)
        if doRestartCooldown then doRestartCooldown() end
        return
    end

    for i = 1, 4 do
        if not yourOffer[i] then
            invQty[itemKey] = rem - 1
            if isFake(itemKey) then
                local dname = fakeDisplayName(itemKey)
                mockInvQty[dname] = (mockInvQty[dname] or rem) - 1
            end
            yourOffer[i]    = itemKey
            offerQty[i]     = 1
            slotOf[itemKey] = i

            local slot = yourSlots[i]
            if slot then
                local info = SyncDB.Weapons and SyncDB.Weapons[itemKey]
                if info then
                    pcall(function() ItemSvc:ApplyItemToFrame(slot, info, 1) end)
                    pcall(function() ItemSvc:ApplyTags(slot, info) end)
                end
                -- Copy rarity color from the inventory cell directly --
                -- ApplyItemToFrame may set wrong color on offer slots.
                -- The cloned inventory cell already has correct styling.
                local srcCell = invCells[itemKey]
                local srcInF  = srcCell and srcCell:FindFirstChild("ItemName")
                local dstInF  = slot:FindFirstChild("ItemName")
                if srcInF and dstInF then
                    dstInF.BackgroundColor3       = srcInF.BackgroundColor3
                    dstInF.BackgroundTransparency = 0
                    -- Copy BG image (rarity texture overlay) if present
                    local srcBG = srcInF:FindFirstChild("BG")
                    local dstBG = dstInF:FindFirstChild("BG")
                    if srcBG and dstBG then
                        dstBG.Image            = srcBG.Image
                        dstBG.ImageColor3      = srcBG.ImageColor3
                        dstBG.BackgroundColor3 = srcBG.BackgroundColor3
                        dstBG.Visible          = true
                    end
                elseif dstInF then
                    dstInF.BackgroundTransparency = 0
                end
                slot.Visible = true
                local am = find(slot, "Container", "Amount")
                if am then am.Text = ""; am.Visible = false end
            end

            updateCellVis(itemKey)
            if doRestartCooldown then doRestartCooldown() end
            return
        end
    end
end

