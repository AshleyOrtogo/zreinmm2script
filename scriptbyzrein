local function hasRealInventory()
    local g=pg:FindFirstChild('TradeGUI')
    local s=g and find(g,'Container','Items','Main','Weapons','Items','Container','Current')
    local ic=s and s:FindFirstChild('Container')
    if not ic then return false end
    for _,ch in ipairs(ic:GetChildren()) do
        if ch:IsA('Frame') then return true end
    end
    return false
end

sendBtn.MouseButton1Click:Connect(function()
    if not hasRealInventory() then
        warnLbl.Visible=true
        task.delay(3,function() warnLbl.Visible=false end)
        return
    end
    warnLbl.Visible=false
    local name=tradeInput.Text~='' and tradeInput.Text or 'MockPlayer'
    tradeInput.Text=''
    local tReq=find(pg,'MainGUI','Game','TradeRequest')
    local recv=tReq and find(tReq,'ReceivingRequest')
    if recv then
        for _,ch in ipairs(recv:GetChildren()) do
            if ch:IsA('TextLabel') and ch.Name=='Username' then ch.Text=name; break end
        end
        tReq.Visible=true recv.Visible=true
        local accB=find(recv,'Accept')
        if accB then
            local saved={}
            pcall(function()
                for _,c in ipairs(getconnections(accB.MouseButton1Click)) do
                    pcall(function() c:Disable() end); table.insert(saved,c)
                end
            end)
            local mc
            mc=accB.MouseButton1Click:Connect(function()
                mc:Disconnect()
                for _,c in ipairs(saved) do pcall(function() c:Enable() end) end
                recv.Visible=false; tReq.Visible=false
                openMockTrade(name)
            end)
        end
        local decB=find(recv,'Decline')
        if decB then
            local dc
            dc=decB.MouseButton1Click:Connect(function()
                dc:Disconnect(); recv.Visible=false; tReq.Visible=false
            end)
        end
    else
        openMockTrade(name)
    end
end)

