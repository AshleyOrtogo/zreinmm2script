-- ================================================================
--  HOOK TARGETS  (lazy-loaded once)
-- ================================================================
local ProfileData    = nil
local SyncDB         = nil
local InventoryService = nil

local function getHooks()
    if ProfileData then return true end
    local ok1, pd = pcall(function()
        return require(RS:WaitForChild('Modules'):WaitForChild('ProfileData'))
    end)
    local ok2, sync = pcall(function()
        return require(RS:WaitForChild('Database'):WaitForChild('Sync'))
    end)
    local ok3, inv = pcall(function()
        return require(RS:WaitForChild('ClientServices'):WaitForChild('InventoryService'))
    end)
    if ok1 and ok2 and ok3 then
        ProfileData     = pd
        SyncDB          = sync
        InventoryService = inv
        return true
    end
    warn('[KnifeSpawner] Hook targets not ready yet:', ok1, ok2, ok3)
    return false
end

-- ================================================================
--  INJECT INTO GAME DATA + RE-RENDER
-- ================================================================
local function injectIntoGame(uid, item)
    if not getHooks() then return false end

    -- 1. Add to Database.Sync.Weapons so ItemService can find it
    if SyncDB.Weapons then
        -- Prefer Season/Event from the LIVE SyncDB entry (real game has correct tab data)
        -- Fall back to our static DB values if the key isn't in live SyncDB
        local liveEntry = SyncDB.Weapons[item.dbKey]
        local realSeason = (liveEntry and liveEntry.Season) or item.season or nil
        local realEvent  = (liveEntry and liveEntry.Event)  or item.event  or nil
        -- Normalize 'None' strings to nil
        if realSeason == 'None' then realSeason = nil end
        if realEvent  == 'None' then realEvent  = nil end

        SyncDB.Weapons[uid] = {
            Name     = item.name,
            ItemName = item.name,
            Rarity   = item.rarity,
            Image    = item.image,
            ItemType = item.itemType or 'Knife',
            Chroma   = item.chroma or nil,
            FX       = item.fx or nil,
            Season   = realSeason,
            Event    = realEvent,
            _isFake  = true,
        }
    end

    -- 2. Add to ProfileData.Weapons.Owned so inventory renders it
    if ProfileData and ProfileData.Weapons and ProfileData.Weapons.Owned then
        -- Owned is a dict: key=itemKey, value=quantity
        ProfileData.Weapons.Owned[uid] = item.quantity
    end

    -- 3. Force inventory re-render via InventoryService if it's already open
    -- InventoryService stores the active info table in Inventory2 script scope
    -- We fire InventoryDataChanged so AutoUpdate picks it up
    local invDataChanged = RS:FindFirstChild('Remotes')
        and RS.Remotes:FindFirstChild('Inventory')
        and RS.Remotes.Inventory:FindFirstChild('InventoryDataChanged')
    if invDataChanged then
        invDataChanged:Fire('Weapons', uid, item.quantity)
    end

    return true
end

local function removeFromGame(uid)
    if not getHooks() then return end
    -- Remove from data first
    if SyncDB and SyncDB.Weapons then
        SyncDB.Weapons[uid] = nil
    end
    if ProfileData and ProfileData.Weapons and ProfileData.Weapons.Owned then
        ProfileData.Weapons.Owned[uid] = nil
    end
    -- Fire removal via InventoryDataChanged (qty=0 triggers RemoveItem in InventoryService)
    local invDataChanged = RS:FindFirstChild('Remotes')
        and RS.Remotes:FindFirstChild('Inventory')
        and RS.Remotes.Inventory:FindFirstChild('InventoryDataChanged')
    if invDataChanged then
        pcall(function() invDataChanged:Fire('Weapons', uid, 0) end)
    end
    -- Also try direct frame destruction as fallback
    pcall(function()
        local invGui = game:GetService('Players').LocalPlayer:WaitForChild('PlayerGui', 1)
        if not invGui then return end
        local invContainer = invGui:FindFirstChild('InventoryGui', true)
            or invGui:FindFirstChild('Inventory', true)
        if invContainer then
            for _, frame in ipairs(invContainer:GetDescendants()) do
                if frame:IsA('Frame') and frame.Name == uid then
                    frame:Destroy()
                end
            end
        end
    end)
end

-- ================================================================
--  VISUAL EQUIP
-- ================================================================
local EquipService = nil
local function getEquipService()
    if EquipService then return EquipService end
    local cs = RS:FindFirstChild('ClientServices')
    if cs then
        for _, m in ipairs(cs:GetChildren()) do
            if m.Name == 'EquipService' or m.Name:find('Equip') then
                local ok, svc = pcall(require, m)
                if ok and svc and svc.EquipItem then
                    EquipService = svc; return EquipService
                end
            end
        end
    end
    return nil
end

function EquipFakeItem(uid)
    if not uid or not fakeItems[uid] then return end
    local item = fakeItems[uid]
    if not getHooks() then return end

    local itype = item.itemType or 'Knife'

    -- 1. Make sure fake item is still in SyncDB so ItemService can resolve it
    if SyncDB and SyncDB.Weapons and not SyncDB.Weapons[uid] then
        local liveEntry = SyncDB.Weapons[item.dbKey]
        local realSeason = (liveEntry and liveEntry.Season) or item.season or nil
        local realEvent  = (liveEntry and liveEntry.Event)  or item.event  or nil
        if realSeason == 'None' then realSeason = nil end
        if realEvent  == 'None' then realEvent  = nil end
        SyncDB.Weapons[uid] = {
            Name=item.name, ItemName=item.name, Rarity=item.rarity,
            Image=item.image, ItemType=itype,
            Chroma=item.chroma or nil, FX=item.fx or nil,
            Season=realSeason, Event=realEvent, _isFake=true,
        }
    end

    -- 2. Set ProfileData equipped slot
    if ProfileData and ProfileData.Weapons then
        ProfileData.Weapons.Equipped = ProfileData.Weapons.Equipped or {}
        ProfileData.Weapons.Equipped[itype] = uid
    end

    -- 3. Fire EquippedChanged so the equip container UI updates visually
    -- Must use the module's own cached BindableEvent, not the script child path,
    -- because EquipService.BindEquipContainer connected to the module-level event.
    local fired = false

    -- Method A: fire through the required module table (most reliable)
    local svc = getEquipService()
    if svc and svc.EquippedChanged then
        pcall(function() svc.EquippedChanged:Fire(itype, uid) end)
        fired = true
    end

    -- Method B: fallback -- fire the BindableEvent child of the script directly
    if not fired then
        local equippedChanged = RS:FindFirstChild('ClientServices')
            and RS.ClientServices:FindFirstChild('EquipService')
            and RS.ClientServices.EquipService:FindFirstChild('EquippedChanged')
        if equippedChanged then
            pcall(function() equippedChanged:Fire(itype, uid) end)
            fired = true
        end
    end

    -- Method C: if the module exposes EquipItem, call it directly so it sets
    -- ProfileData AND fires EquippedChanged internally in one shot
    if not fired and svc and svc.EquipItem then
        pcall(function() svc:EquipItem(itype, uid) end)
    end

    -- 4. Tell the server we equipped DEFAULT item (so gameplay still works normally)
    --    This means visually = fake skin, server-side = normal default knife/gun
    local equipRemote = RS:FindFirstChild('Remotes')
        and RS.Remotes:FindFirstChild('Inventory')
        and RS.Remotes.Inventory:FindFirstChild('Equip')
    if equipRemote then
        local defaultKey = itype == 'Gun' and 'DefaultGun' or 'DefaultKnife'
        pcall(function() equipRemote:FireServer(defaultKey, 'Weapons') end)
    end
end


