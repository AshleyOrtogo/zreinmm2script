-- ================================================================
--  ACCEPT / DECLINE ACTIONS
-- ================================================================
local function setupActions()
    local actF      = find(C, "Trade", "Actions")
    local accF      = actF  and find(actF,  "Accept")
    local addItemF  = accF  and find(accF,  "AddItem")
    local coolF     = accF  and find(accF,  "Cooldown")
    local confirmF  = accF  and find(accF,  "Confirm")
    local cancelF   = accF  and find(accF,  "Cancel")
    local decF      = actF  and find(actF,  "Decline")
    local yourAccF  = find(C, "Trade", "YourOffer",  "Accepted")
    local theirAccF = find(C, "Trade", "TheirOffer", "Accepted")
    local coolTitle = coolF and find(coolF, "Title")

    -- Replace buttons fresh every open (clears all previous connections)
    local function freshReplace(parent, name)
        if not parent then return nil end
        local old = parent:FindFirstChild(name)
        if not old then return nil end
        local nb = old:Clone(); old:Destroy(); nb.Parent = parent
        return nb
    end
    local accBtn     = freshReplace(accF,     "ActionButton")
    local addItemBtn = freshReplace(addItemF, "ActionButton")
    local confirmBtn = freshReplace(confirmF, "ActionButton")
    local cancelBtn  = freshReplace(cancelF,  "ActionButton")
    local decBtn     = freshReplace(decF,     "ActionButton")

    local GRAY  = Color3.fromRGB(90, 90, 90)
    local GREEN = Color3.fromRGB(55, 200, 60)
    local GRAY_STROKE = Color3.fromRGB(90, 90, 90)
    local GREEN_STROKE = Color3.fromRGB(55, 200, 60)

    -- Get the UIStroke on accF (the green border)
    local accStroke = accF and accF:FindFirstChildOfClass("UIStroke")

    local cdDone    = false
    local accepted  = false
    local tickToken = nil

    local function grayTop()
        if accF      then pcall(function() accF.BackgroundColor3      = GRAY end) end
        if addItemF  then pcall(function() addItemF.BackgroundColor3  = GRAY end) end
        if accBtn    then pcall(function() accBtn.BackgroundColor3    = GRAY; accBtn.AutoButtonColor    = false end) end
        if addItemBtn then pcall(function() addItemBtn.BackgroundColor3 = GRAY; addItemBtn.AutoButtonColor = false end) end
        if accStroke then pcall(function() accStroke.Color = GRAY_STROKE end) end
    end

    local function greenTop()
        if accF      then pcall(function() accF.BackgroundColor3      = GREEN end) end
        if addItemF  then pcall(function() addItemF.BackgroundColor3  = GREEN end) end
        if accBtn    then pcall(function() accBtn.BackgroundColor3    = GREEN; accBtn.AutoButtonColor    = true end) end
        if addItemBtn then pcall(function() addItemBtn.BackgroundColor3 = GREEN; addItemBtn.AutoButtonColor = true end) end
        if accStroke then pcall(function() accStroke.Color = GREEN_STROKE end) end
    end

    local function fullReset()
        cdDone    = false
        accepted  = false
        tickToken = nil
        -- Force gray explicitly before grayTop (clone may start green)
        if accF then
            pcall(function() accF.BackgroundColor3 = GRAY end)
            accF.Visible               = true
            accF.BackgroundTransparency = 0
        end
        grayTop()
        if coolF     then coolF.Visible     = false end
        if addItemF  then addItemF.Visible  = false end
        if confirmF  then confirmF.Visible  = false end
        if cancelF   then cancelF.Visible   = false end
        if yourAccF  then yourAccF.Visible  = false end
        if theirAccF then theirAccF.Visible = false end
        if accBtn    then accBtn.Visible    = true  end
        -- Restore title/gradient visibility
        local title = accF and accF:FindFirstChild("Title")
        local grad  = accF and accF:FindFirstChild("Gradient")
        if title then title.Visible = true end
        if grad  then grad.Visible  = true end
    end

    doGrayOut = function()
        tickToken = nil
        fullReset()
    end

    local function startCooldown()
        cdDone    = false
        accepted  = false
        local myToken = {}
        tickToken     = myToken

        grayTop()
        if coolF    then coolF.Visible    = true  end
        if addItemF then addItemF.Visible = false end
        if confirmF then confirmF.Visible = false end
        if cancelF  then cancelF.Visible  = false end
        if accBtn   then accBtn.Visible   = true  end

        local t = 6
        local function tick()
            if tickToken ~= myToken or not tradeOpen then return end
            if coolTitle then
                coolTitle.Text = "Please wait ("..t..") before accepting."
            end
            if t <= 0 then
                tickToken = nil
                if not offerIsEmpty() then
                    cdDone = true
                    if coolF    then coolF.Visible    = false end
                    if addItemF then addItemF.Visible = true  end
                    greenTop()
                else
                    doGrayOut()
                end
                return
            end
            t = t - 1
            task.delay(1, tick)
        end
        tick()
    end

    doRestartCooldown = function()
        if not tradeOpen then return end
        tickToken = nil
        cdDone    = false
        startCooldown()
    end

    local function onAccept()
        if accepted or not cdDone then return end
        if addItemF then addItemF.Visible = false end
        if cancelF  then cancelF.Visible  = false end
        if confirmF then confirmF.Visible = true  end
    end

    if accBtn     then accBtn.MouseButton1Click:Connect(onAccept)     end
    if addItemBtn then addItemBtn.MouseButton1Click:Connect(onAccept) end

    if confirmBtn then
        confirmBtn.MouseButton1Click:Connect(function()
            if accepted then return end
            accepted = true
            if confirmF then confirmF.Visible = false end
            if addItemF then addItemF.Visible = false end
            if accBtn   then accBtn.Visible   = false end
            -- Show CANCEL button (matches real trade behavior)
            if cancelF  then cancelF.Visible  = true  end
            -- Make accF blank (can't hide -- Decline is sibling, layout reflows)
            if accF then
                accF.BackgroundTransparency = 1
                local title = accF:FindFirstChild("Title")
                local grad  = accF:FindFirstChild("Gradient")
                if title then title.Visible = false end
                if grad  then grad.Visible  = false end
            end
            if yourAccF then yourAccF.Visible = true end
            -- Commit fake item qty to PD + fire InventoryDataChanged to refresh real inventory
            local invDC = RS:FindFirstChild("Remotes")
                and RS.Remotes:FindFirstChild("Inventory")
                and RS.Remotes.Inventory:FindFirstChild("InventoryDataChanged")

            for i = 1, 4 do
                local key = yourOffer[i]
                local qty = offerQty[i] or 0
                if key and qty > 0 and isFake(key) then
                    local fakeData = SyncDB.Weapons and SyncDB.Weapons[key]
                    local dispName = fakeData and fakeData.ItemName
                    if dispName and SyncDB.Weapons then
                        -- Collect all matching fake uids safely before modifying
                        local matchingUids = {}
                        for uid, data in pairs(SyncDB.Weapons) do
                            if data._isFake and data.ItemName == dispName then
                                table.insert(matchingUids, uid)
                            end
                        end
                        -- Decrement PD + fire UI refresh per uid
                        local remaining = qty
                        for _, uid in ipairs(matchingUids) do
                            if remaining <= 0 then break end
                            pcall(function()
                                local cur = PD.Weapons.Owned[uid] or 0
                                local take = math.min(cur, remaining)
                                remaining = remaining - take
                                local newQty = cur - take
                                if newQty <= 0 then
                                    PD.Weapons.Owned[uid] = nil
                                    SyncDB.Weapons[uid]   = nil
                                    if _G.MM2FakeItems then _G.MM2FakeItems[uid] = nil end
                                    if invDC then pcall(function() invDC:Fire("Weapons", uid, 0) end) end
                                else
                                    PD.Weapons.Owned[uid] = newQty
                                    if invDC then pcall(function() invDC:Fire("Weapons", uid, newQty) end) end
                                end
                            end)
                        end
                        if mockInvQty[dispName] then
                            mockInvQty[dispName] = math.max(0, mockInvQty[dispName])
                        end
                    end
                end
            end
            task.delay(1, closeMockTrade)
        end)
    end

    if cancelBtn then
        cancelBtn.MouseButton1Click:Connect(function()
            accepted = false
            if cancelF   then cancelF.Visible   = false end
            if yourAccF  then yourAccF.Visible  = false end
            if theirAccF then theirAccF.Visible = false end
            if addItemF  then addItemF.Visible  = true  end
            if accBtn    then accBtn.Visible    = false end
        end)
    end

    if decBtn then decBtn.MouseButton1Click:Connect(closeMockTrade) end

    fullReset()
end

-- ================================================================
--  POPULATE INVENTORY
-- ================================================================
local function populateInventory()
    local scroll = find(C, "Items", "Main", "Weapons", "Items", "Container", "Current")
    if not scroll then warn("[ZREIN] scroll not found"); return end

    local old = scroll:FindFirstChild("MT_Container")
    if old then old:Destroy() end

    invQty   = {}
    invCells = {}

    local owned = {}
    pcall(function()
        for k, v in pairs(PD.Weapons.Owned) do
            if type(v) == "number" and v > 0 then owned[k] = v end
        end
    end)

    -- Build nameToKey: display name -> itemKey
    -- Fake items get their uid as the key. If multiple fake uids share the same
    -- display name (e.g. x30 Harvesters = 30 separate FAKE_Harvester_xxx uids),
    -- we pick the first fake uid as the representative key and sum their PD qtys.
    local nameToKey     = {}
    local fakeQtyByName = {}  -- display name -> total qty across all fake uids
    if SyncDB.Weapons then
        for key, data in pairs(SyncDB.Weapons) do
            if data.ItemName then
                if data._isFake then
                    -- Accumulate total fake qty for this display name
                    local q = (owned[key] or 0)
                    fakeQtyByName[data.ItemName] = (fakeQtyByName[data.ItemName] or 0) + q
                    -- Use first fake uid encountered as the representative key
                    if not nameToKey[data.ItemName] then
                        nameToKey[data.ItemName] = key
                    end
                else
                    if not nameToKey[data.ItemName] then
                        nameToKey[data.ItemName] = key
                    end
                end
            end
        end
    end
    -- For any name that has fake items, override the nameToKey to the fake uid
    -- (already done above since fake entries write first if found first,
    --  but we force it explicitly here to be safe)
    if SyncDB.Weapons then
        for key, data in pairs(SyncDB.Weapons) do
            if data.ItemName and data._isFake then
                nameToKey[data.ItemName] = key  -- last fake uid wins -- all share same mockInvQty logic
            end
        end
    end

    -- PRIMARY: clone live TradeGUI inventory
    local realGUI    = pg:FindFirstChild("TradeGUI")
    local realScroll = realGUI and find(realGUI, "Container", "Items", "Main",
                           "Weapons", "Items", "Container", "Current")
    local realIC     = realScroll and realScroll:FindFirstChild("Container")

    local realCount = 0
    if realIC then
        for _, ch in ipairs(realIC:GetChildren()) do
            if ch:IsA("Frame") then realCount = realCount + 1 end
        end
    end

    if realIC and realCount > 0 then
        local ic = realIC:Clone()
        ic.Name                   = "MT_Container"
        ic.BackgroundTransparency = 1
        ic.Parent                 = scroll

        for _, d in ipairs(ic:GetDescendants()) do
            if d:IsA("LocalScript") or d:IsA("Script") or d:IsA("UIStroke") then
                d:Destroy()
            end
        end

        local count = 0
        for _, cell in ipairs(ic:GetChildren()) do
            if cell:IsA("Frame") then
                count = count + 1

                local lbl      = find(cell, "ItemName", "Label")
                local dispName = lbl and lbl.Text or ""
                local itemKey  = nameToKey[dispName] or dispName

                cell.Name = itemKey

                -- Fake items: use persistent qty keyed by display name (stable)
                -- Real items: always read fresh from PD
                local qty
                if isFake(itemKey) then
                    if mockInvQty[dispName] == nil then
                        -- First time seen -- snapshot total qty across all fake uids
                        mockInvQty[dispName] = fakeQtyByName[dispName] or owned[itemKey] or 1
                    end
                    qty = mockInvQty[dispName]
                else
                    qty = owned[itemKey] or 1
                end
                invQty[itemKey]   = qty
                invCells[itemKey] = cell

                local am = find(cell, "Container", "Amount")
                if am then
                    am.Text    = qty > 1 and ("x"..qty) or ""
                    am.Visible = qty > 1
                end

                -- Wire ActionButton -- create if missing
                local con    = cell:FindFirstChild("Container")
                local oldBtn = con and con:FindFirstChild("ActionButton")
                local btn
                if oldBtn then
                    btn = oldBtn:Clone()
                    oldBtn:Destroy()
                    btn.Parent = con
                else
                    btn = Instance.new("TextButton")
                    btn.Name               = "ActionButton"
                    btn.Text               = ""
                    btn.Size               = UDim2.new(1, 0, 1, 0)
                    btn.BackgroundTransparency = 1
                    btn.ZIndex             = 10
                    btn.Parent             = con or cell
                end
                local key = itemKey
