local function wipeSlot(s)
    if not s then return end
    local ic    = find(s, "Container", "Icon")
    local lb    = find(s, "ItemName", "Label") or find(s, "ItemName", "ColoredName")
    local am    = find(s, "Container", "Amount")
    local inF   = s:FindFirstChild("ItemName")
    local bgImg = inF and inF:FindFirstChild("BG")
    local tags  = s:FindFirstChild("Tags")
    if ic   then ic.Image = "" end
    if lb   then lb.Text  = "" end
    if am   then am.Text  = ""; am.Visible = false end
    if inF  then inF.BackgroundTransparency = 1 end
    if bgImg then bgImg.Visible = false end
    if tags then
        for _, t in ipairs(tags:GetChildren()) do
            if t:IsA("Frame") then t.Visible = false end
        end
    end
    s.Visible = false
end

