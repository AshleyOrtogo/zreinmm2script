local function wireSearch()
    local box    = find(C, "Items", "Tabs", "Search", "Container", "SearchText")
    local scroll = find(C, "Items", "Main", "Weapons", "Items", "Container", "Current")
    if not box or not scroll then return end
    box:GetPropertyChangedSignal("Text"):Connect(function()
        local q  = box.Text:lower()
        local ic = scroll:FindFirstChild("MT_Container")
        if not ic then return end
        for _, ch in ipairs(ic:GetChildren()) do
            if ch:IsA("Frame") then
                if (invQty[ch.Name] or 0) <= 0 then
                    ch.Visible = false
                elseif q == "" then
                    ch.Visible = true
                else
                    local lbl = find(ch, "ItemName", "Label")
                    ch.Visible = (lbl and lbl.Text or ch.Name):lower():find(q,1,true) ~= nil
                end
            end
        end
    end)
end

