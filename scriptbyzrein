local function setupGui()
    local real = pg:FindFirstChild("TradeGUI")
    if not real then warn("[ZREIN] TradeGUI not found!"); return false end

    local old = pg:FindFirstChild("MockTradeGUI")
    if old then old:Destroy() end

    mockGui         = real:Clone()
    mockGui.Name    = "MockTradeGUI"
    mockGui.Enabled = false
    mockGui.Parent  = pg

    for _, d in ipairs(mockGui:GetDescendants()) do
        if d:IsA("LocalScript") or d:IsA("Script") or d:IsA("UIStroke") then
            d:Destroy()
        end
    end

    for _, d in ipairs(mockGui:GetDescendants()) do
        if d:IsA("TextBox") then
            if d.Name == "SearchText" then
                d.Text = ""
                d.PlaceholderText = "Search"
            else
                d.Text = ""
                d.PlaceholderText = ""
                d.Visible = false
            end
        end
    end

    C = find(mockGui, "Container")
