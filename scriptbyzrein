-- Add button logic
addBtn.MouseButton1Click:Connect(function()
    local entry=selEntry
    if not entry then
        local q=searchBox.Text:lower()
        if q~='' then
            for _,e in ipairs(ITEM_LIST) do
                if e.name:lower()==q or e.key:lower()==q then entry=e; break end
            end
            if not entry then
                for _,e in ipairs(ITEM_LIST) do
                    if e.name:lower():find(q,1,true) then entry=e; break end
                end
            end
        end
    end
    if not entry then setStatus('[ERR] Select or type an item name',true); return end
    local qty=math.clamp(math.floor(tonumber(qtyBox.Text) or 1),1,99)
    local rarOv=rarityBox.Text~='' and rarityBox.Text or nil
    if rarOv and not RARITY_COLOR[rarOv] then setStatus('[ERR] Unknown rarity: '..rarOv,true); return end
    local useE=entry
    if rarOv then
        useE={key=entry.key,name=entry.name,rarity=rarOv,image=entry.image,
            chroma=entry.chroma,fx=entry.fx,itemType=entry.itemType,
            season=entry.season,event=entry.event}
    end
    local uid='FAKE_'..useE.key..'_'..HttpService:GenerateGUID(false):sub(1,8)
    local item={
        name=useE.name,rarity=useE.rarity,image=useE.image,
        chroma=useE.chroma or false,fx=useE.fx or nil,quantity=qty,
        itemType=useE.itemType or 'Knife',season=useE.season or nil,
        event=useE.event or nil,dbKey=useE.key,uid=uid,isFake=true,
    }
    fakeItems[uid]=item _G.MM2FakeItems=fakeItems
    if not getHooks() then setStatus('[ERR] Game hooks not ready',true); fakeItems[uid]=nil; return end
    if SyncDB.Weapons then
        local live=SyncDB.Weapons[item.dbKey]
        local rs=(live and live.Season) or item.season or nil
        local re=(live and live.Event)  or item.event  or nil
        if rs=='None' then rs=nil end if re=='None' then re=nil end
        SyncDB.Weapons[uid]={Name=item.name,ItemName=item.name,Rarity=item.rarity,
            Image=item.image,ItemType=item.itemType or 'Knife',
            Chroma=item.chroma or nil,FX=item.fx or nil,
            Season=rs,Event=re,_isFake=true}
    end
    if ProfileData and ProfileData.Weapons and ProfileData.Weapons.Owned then
        ProfileData.Weapons.Owned[uid]=qty
    end
    local invDC=RS:FindFirstChild('Remotes') and RS.Remotes:FindFirstChild('Inventory')
        and RS.Remotes.Inventory:FindFirstChild('InventoryDataChanged')
    if invDC then invDC:Fire('Weapons',uid,qty) end
    setStatus(string.format('[OK] Added "%s" (%s) x%d',item.name,item.rarity,qty))
    refreshAdded()
end)

